@prefix rml:   <http://semweb.mmlab.be/ns/rml#> .
@prefix rr:    <http://www.w3.org/ns/r2rml#> .
@prefix ql:    <http://semweb.mmlab.be/ns/ql#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix sosa:  <http://www.w3.org/ns/sosa/> .
@prefix dq:    <http://example.org/dq#> .
@prefix agri:  <http://example.org/agri#> .

# =============================================================================
# RML Mapping — Vendor B (epoch timestamp ms, fraction 0-1, °F)
# Conversions requises :
#   fraction → % : value * 100
#   °F → °C      : (value - 32) * 5/9
#   epoch ms → ISO : datetime conversion
# =============================================================================

<#VendorBMapping>
    rml:logicalSource [
        rml:source "vendor_b_data.json" ;
        rml:referenceFormulation ql:JSONPath ;
        rml:iterator "$"
    ] ;

    rr:subjectMap [
        rr:template "http://example.org/obs/B/{node}/{ts}" ;
        rr:class sosa:Observation
    ] ;

    rr:predicateObjectMap [
        rr:predicate dq:vendorId ;
        rr:objectMap [
            rr:constant "B" ;
            rr:datatype xsd:string
        ]
    ] ;

    # Humidité : fraction → % (conversion côté normalizer)
    rr:predicateObjectMap [
        rr:predicate dq:humidity_raw ;
        rr:objectMap [
            rml:reference "hum" ;
            rr:datatype xsd:decimal
        ]
    ] ;

    # Humidité sol : fraction → %
    rr:predicateObjectMap [
        rr:predicate dq:moisture_raw ;
        rr:objectMap [
            rml:reference "moi" ;
            rr:datatype xsd:decimal
        ]
    ] ;

    # Température : °F → °C (conversion côté normalizer)
    rr:predicateObjectMap [
        rr:predicate dq:temperature_raw ;
        rr:objectMap [
            rml:reference "temp_f" ;
            rr:datatype xsd:decimal
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate dq:ph ;
        rr:objectMap [
            rml:reference "ph" ;
            rr:datatype xsd:decimal
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate dq:oxygen ;
        rr:objectMap [
            rml:reference "oxy" ;
            rr:datatype xsd:decimal
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate dq:ammonia ;
        rr:objectMap [
            rml:reference "amm" ;
            rr:datatype xsd:decimal
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate dq:turbidity ;
        rr:objectMap [
            rml:reference "turb" ;
            rr:datatype xsd:decimal
        ]
    ] ;

    # Timestamp epoch ms (conversion côté normalizer)
    rr:predicateObjectMap [
        rr:predicate dq:timestamp_raw ;
        rr:objectMap [
            rml:reference "ts" ;
            rr:datatype xsd:long
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate sosa:madeBySensor ;
        rr:objectMap [
            rr:template "http://example.org/sensor/{node}"
        ]
    ] .
