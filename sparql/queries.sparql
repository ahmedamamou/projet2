# ─────────────────────────────────────────────────────────────────────────────
# Q9 : Observations nécessitant une action d'irrigation (moisture < 30%, Q ≥ 0.7)
# ─────────────────────────────────────────────────────────────────────────────
# SELECT ?obs ?ts ?moisture ?Q ?vendor
# WHERE {
