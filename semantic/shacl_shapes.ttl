@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix sosa:  <http://www.w3.org/ns/sosa/> .
@prefix dq:    <http://example.org/dq#> .
@prefix agri:  <http://example.org/agri#> .
@prefix qudt:  <http://qudt.org/schema/qudt/> .
@prefix unit:  <http://qudt.org/vocab/unit/> .
@prefix shapes: <http://example.org/shapes#> .

# =============================================================================
# SHACL Shapes — 10 contraintes de base
# Correspondance avec l'article : sections 11 (Shapes 1-10)
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# SHAPE 1 : Structure de l'observation BaseObservation
# ─────────────────────────────────────────────────────────────────────────────
shapes:ObservationStructure a sh:NodeShape ;
    sh:targetClass sosa:Observation ;
    rdfs:label "BaseObservation structure"@en ;
    sh:property [
        sh:path sosa:resultTime ;
        sh:minCount 1 ;
        sh:message "An observation must have a resultTime timestamp"@en
    ] ;
    sh:property [
        sh:path sosa:madeBySensor ;
        sh:minCount 1 ;
        sh:message "An observation must reference its sensor"@en
    ] ;
    sh:property [
        sh:path sosa:observedProperty ;
        sh:minCount 1 ;
        sh:message "An observation must specify the observed property"@en
    ] ;
    sh:property [
        sh:path sosa:hasFeatureOfInterest ;
        sh:minCount 1 ;
        sh:message "An observation must reference its feature of interest"@en
    ] .

# ─────────────────────────────────────────────────────────────────────────────
# SHAPE 2 : SoilMoisture range [0, 100] %
# ─────────────────────────────────────────────────────────────────────────────
shapes:SoilMoistureRange a sh:NodeShape ;
    sh:targetClass sosa:Observation ;
    rdfs:label "SoilMoisture range [0-100%]"@en ;
    sh:property [
        sh:path dq:soilMoisture ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 100.0 ;
        sh:message "Soil moisture out of range [0, 100] %"@en
    ] .

# ─────────────────────────────────────────────────────────────────────────────
# SHAPE 3 : AirTemperature range [-40, 60] °C
# ─────────────────────────────────────────────────────────────────────────────
shapes:AirTemperatureRange a sh:NodeShape ;
    sh:targetClass sosa:Observation ;
    rdfs:label "AirTemperature range [-40, 60°C]"@en ;
    sh:property [
        sh:path dq:airTemperature ;
        sh:minInclusive -40.0 ;
        sh:maxInclusive 60.0 ;
        sh:message "Air temperature out of range [-40, 60] °C"@en
    ] .

# ─────────────────────────────────────────────────────────────────────────────
# SHAPE 4 : SoilTemperature range [-10, 60] °C
# ─────────────────────────────────────────────────────────────────────────────
shapes:SoilTemperatureRange a sh:NodeShape ;
    sh:targetClass sosa:Observation ;
    rdfs:label "SoilTemperature range [-10, 60°C]"@en ;
    sh:property [
        sh:path dq:soilTemperature ;
        sh:minInclusive -10.0 ;
        sh:maxInclusive 60.0 ;
        sh:message "Soil temperature out of range [-10, 60] °C"@en
    ] .

# ─────────────────────────────────────────────────────────────────────────────
# SHAPE 5 : SoilPH range [0, 14]
# ─────────────────────────────────────────────────────────────────────────────
shapes:SoilPHRange a sh:NodeShape ;
    sh:targetClass sosa:Observation ;
    rdfs:label "SoilPH range [0-14]"@en ;
    sh:property [
        sh:path dq:soilPH ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 14.0 ;
        sh:message "Soil pH out of range [0, 14]"@en
    ] .

# ─────────────────────────────────────────────────────────────────────────────
# SHAPE 6 : Illuminance range [0, 200000] lux
# ─────────────────────────────────────────────────────────────────────────────
shapes:IlluminanceRange a sh:NodeShape ;
    sh:targetClass sosa:Observation ;
    rdfs:label "Illuminance range [0-200000 lux]"@en ;
    sh:property [
        sh:path dq:illuminance ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 200000.0 ;
        sh:message "Illuminance out of range [0, 200000] lux"@en
    ] .

# ─────────────────────────────────────────────────────────────────────────────
# SHAPE 7 : IrrigationState [0, 1] binary
# ─────────────────────────────────────────────────────────────────────────────
shapes:IrrigationStateRange a sh:NodeShape ;
    sh:targetClass sosa:Observation ;
    rdfs:label "IrrigationState binary [0/1]"@en ;
    sh:property [
        sh:path dq:irrigationState ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 1.0 ;
        sh:message "Irrigation state must be 0 or 1"@en
    ] .

# ─────────────────────────────────────────────────────────────────────────────
# SHAPE 8 : FertilizationDose range [0, 500] kg/ha
# ─────────────────────────────────────────────────────────────────────────────
shapes:FertilizationDoseRange a sh:NodeShape ;
    sh:targetClass sosa:Observation ;
    rdfs:label "FertilizationDose range [0-500 kg/ha]"@en ;
    sh:property [
        sh:path dq:fertilizationDose ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 500.0 ;
        sh:message "Fertilization dose out of range [0, 500] kg/ha"@en
    ] .

# ─────────────────────────────────────────────────────────────────────────────
# SHAPE 9 : BatteryLevel range [0, 100] %
# ─────────────────────────────────────────────────────────────────────────────
shapes:BatteryLevelRange a sh:NodeShape ;
    sh:targetClass sosa:Observation ;
    rdfs:label "BatteryLevel range [0-100%]"@en ;
    sh:property [
        sh:path dq:batteryLevel ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 100.0 ;
        sh:message "Battery level out of range [0, 100] %"@en
    ] .

# ─────────────────────────────────────────────────────────────────────────────
# SHAPE 10 : QualityScore range [0, 1]
# ─────────────────────────────────────────────────────────────────────────────
shapes:QualityScoreRange a sh:NodeShape ;
    sh:targetClass sosa:Observation ;
    rdfs:label "QualityScore range [0-1]"@en ;
    sh:property [
        sh:path dq:qualityScore ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 1.0 ;
        sh:message "Quality score must be in [0, 1]"@en
    ] .
